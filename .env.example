# =============================================================================
# Zeni frontend — environment variables (Vite)
# Copy to .env and set values. All VITE_* are exposed to the client bundle.
# =============================================================================

# API base URL (path or full origin). Default /api for same-origin.
VITE_API_BASE_URL=/api
# Dev proxy target when using Vite proxy (see vite.config).
VITE_DEV_API_TARGET=http://localhost:4000
# Optional: API base just for native (Capacitor) builds. Must be a full HTTPS origin.
# VITE_MOBILE_API_BASE_URL=https://api.zeni.example.com

# Socket.IO URL if different from API origin (optional).
# VITE_SOCKET_URL=https://api.zeni.example.com
# Optional: socket URL only for native (Capacitor) builds.
# VITE_MOBILE_SOCKET_URL=https://api.zeni.example.com

# Google Sign-In: Web client ID (same as server GOOGLE_CLIENT_ID from Google Cloud Console).
# VITE_GOOGLE_CLIENT_ID=

# Sentry: frontend error reporting (production). Set to enable.
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics: optional endpoint for key events (search, listing view, contact, payment).
# VITE_ANALYTICS_ENDPOINT=

# Stripe: publishable key for card form (from https://dashboard.stripe.com/apikeys). Leave empty to hide card option.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Bank transfer: shown to user after they confirm. Replace with your real details.
# VITE_PAY_BANK_NAME=Your Bank Name
# VITE_PAY_BANK_ACCOUNT=KES 1234567890

# Landing page contact (real data). Leave empty to hide phone.
# VITE_CONTACT_EMAIL=zeniapp.ke@gmail.com
# VITE_CONTACT_PHONE=+254 7XX XXX XXX

# Social links (real URLs). Leave empty to hide that link.
# VITE_SOCIAL_INSTAGRAM=https://instagram.com/...
# VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/...
# VITE_SOCIAL_TWITTER=https://twitter.com/...
