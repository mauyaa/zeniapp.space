{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://zygomorphic-catrina-zeniapp-c91be0b3.koyeb.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://zygomorphic-catrina-zeniapp-c91be0b3.koyeb.app/uploads/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://zygomorphic-catrina-zeniapp-c91be0b3.koyeb.app/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}