{
  "name": "zeni",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --host --port 5173",
    "dev:server": "npm --prefix server run dev",
    "dev:full": "concurrently -n fe,be -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "build:server": "npm --prefix server run build",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "mobile:doctor": "npx cap doctor",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:server": "npm --prefix server run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "npm --prefix server run test -- --runInBand",
    "seed": "npm --prefix server run seed",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "verify:frontend": "npm run lint && npm run format:check && npm run build && npm run check:bundle && npm run test",
    "verify:backend": "npm --prefix server run lint && npm --prefix server run build && npm --prefix server run test -- --runInBand",
    "verify:e2e": "npm run test:e2e",
    "verify": "npm run verify:frontend && npm run verify:backend && npm run verify:e2e"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@gsap/react": "^2.1.2",
    "@sentry/react": "^7.114.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.8.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^12.0.0",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.1.0",
    "gsap": "^3.14.2",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.17",
    "lucide-react": "^0.522.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.1",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^9.1.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "latest",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "vite-plugin-compression2": "^2.4.0",
    "vitest": "^4.0.18"
  }
}
