{
    "name": "zeni-property-server",
    "version": "1.0.0",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "test": "jest --runInBand",
        "seed": "node -r ts-node/register scripts/seed.ts",
        "clear-chat": "node -r ts-node/register scripts/clear-chat.ts",
        "ensure-welcome-agents": "node -r ts-node/register scripts/ensureWelcomeAgents.ts",
        "backup": "node -r ts-node/register scripts/backup.ts"
    },
    "dependencies": {
        "@sentry/node": "^7.114.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.1",
        "express": "^4.19.2",
        "express-async-errors": "^3.1.1",
        "express-rate-limit": "^7.2.0",
        "google-auth-library": "^10.5.0",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "json2csv": "^6.0.0-alpha.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.3.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "node-cron": "^3.0.3",
        "nodemailer": "^8.0.1",
        "prom-client": "^15.1.1",
        "socket.io": "^4.8.3",
        "stripe": "^20.3.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/morgan": "^1.9.7",
        "@types/node": "^20.11.24",
        "@types/node-cron": "^3.0.11",
        "@types/supertest": "^2.0.16",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-unused-imports": "^3.1.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.2.3",
        "prettier": "^3.2.5",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
