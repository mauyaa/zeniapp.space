# In production: set strong JWT_SECRET and change ADMIN_OTP / ADMIN_STEP_UP_CODE / PAY_STEP_UP_CODE.
# Optional: Google sign-in (create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
PORT=4000
MONGO_URI=mongodb://mongo:27017/zeni
JWT_SECRET=supersecretjwt
# Comma-separated origins. Include Capacitor default for native builds.
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,http://localhost:5175,capacitor://localhost
NODE_ENV=development
# Test-only logging toggles (default false). Keep off for clean CI output.
# REQUEST_LOG_IN_TEST=true
# RBAC_DEBUG=true
# LOG_IN_TEST=true
# CHAT_DEBUG_IN_TEST=true
TRUST_PROXY=false
ADMIN_DOMAIN=zeni.test,gmail.com
ALLOW_PRIVILEGED_SIGNUP=false
ADMIN_OTP=000000
ADMIN_IP_ALLOWLIST=127.0.0.1,::1,100.64.0.0/10,fd7a:115c:a1e0::/48
ADMIN_REQUIRE_TAILNET=false
PAY_ADMIN_REQUIRE_TAILNET=false
TAILNET_EXPECTED_CIDRS=100.64.0.0/10,fd7a:115c:a1e0::/48
ADMIN_STEP_UP_CODE=000000
# M-Pesa Daraja: get from https://developer.safaricom.co.ke. Use "dev" or leave empty for mock (no real STK push).
# Callback URL must be publicly reachable (e.g. ngrok in dev). Safaricom POSTs STK result here.
MPESA_CONSUMER_KEY=changeme
MPESA_CONSUMER_SECRET=changeme
MPESA_SHORTCODE=123456
MPESA_PASSKEY=changeme
MPESA_CALLBACK_URL=http://localhost:4000/api/pay/mpesa/callback
MPESA_CALLBACK_SECRET=
# Stripe: card payments. Get keys from https://dashboard.stripe.com/apikeys
# Webhook: add endpoint https://your-api/api/pay/stripe/webhook, event payment_intent.succeeded, copy signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAY_STEP_UP_CODE=000000
PAY_TX_MAX_PER_HOUR=10
PAY_TX_MAX_AMOUNT_DAY=250000
PAY_DUAL_CONTROL_AMOUNT=50000
PAY_STALE_MINUTES=30
RATE_LIMIT_MAX=300
ADMIN_EMAIL=zeniapp.ke@gmail.com
ADMIN_PASSWORD=ChangeMe123!
AGENT_EMAIL=zeniagent.ke@gmail.com
AGENT_PASSWORD=AgentPass123!
# Welcome chats for new users (Zeni Agent = main; Zeni Support = support; Zeni Admin = admin inbox)
# For Kenya prototype: set these to your admin/support/agent emails; run `npm run seed` so DB matches.
ZENI_AGENT_EMAIL=zeniagent.ke@gmail.com
ZENI_SUPPORT_EMAIL=support@zeni.test
ZENI_ADMIN_EMAIL=admin@zeni.test
# Password for all seeded users (admin, agent, support, test users). Default: ChangeMe123!
SEED_PASSWORD=ChangeMe123!
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
AUDIT_TTL_DAYS=180
AUDIT_WEBHOOK_URL=http://localhost:9000/audit
EVENT_WEBHOOK_URL=http://localhost:9000/events
# Optional: Cloudinary for image uploads (else images stored under /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Resend: email delivery (https://resend.com). Free tier sends from onboarding@resend.dev.
RESEND_API_KEY=
RESEND_FROM=ZENI. <no-reply@zeniapp.space>
